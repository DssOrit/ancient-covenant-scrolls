# Example environment file. Copy to .env (which is gitignored) and
# fill in real values. NEVER commit .env. NEVER put real keys here.
#
# Load is currently a frontend-only PWA — API keys live in the user's
# browser localStorage, not in env vars. This file exists for the
# FUTURE serverless proxy step where keys would move server-side.
#
# Recommended path forward (per SECURITY_PLAN.md task 4):
# Public Load PWA → backend / serverless proxy → these env vars →
# private provider keys → AI provider API.

# ─── AI provider keys (server-side only, never in frontend) ───
OPENROUTER_API_KEY=replace_with_server_side_secret_only
HUGGINGFACE_TOKEN=replace_with_server_side_secret_only
CLOUDFLARE_API_TOKEN=replace_with_server_side_secret_only
CLOUDFLARE_ACCOUNT_ID=replace_with_server_side_account_id
GEMINI_API_KEY=replace_with_server_side_secret_only
ANTHROPIC_API_KEY=replace_with_server_side_secret_only
TOGETHER_API_KEY=replace_with_server_side_secret_only
CEREBRAS_API_KEY=replace_with_server_side_secret_only
PUTER_API_TOKEN=replace_with_server_side_secret_only

# ─── Provider feature flags (boolean — these CAN be in frontend) ───
PUTER_ENABLED=true
POLLINATIONS_ENABLED=true
GEMINI_IMAGE_ENABLED=false

# ─── App config ───
# If app uses VITE-prefixed vars, REMEMBER: VITE_* is visible in
# frontend builds. Never put private keys in VITE_*.
VITE_PUBLIC_APP_NAME=Load
VITE_PUBLIC_APP_VERSION=v17dh
